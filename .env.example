# Cloudflare Pages deploy credentials, consumed by `make deploy`
# (scripts/deploy.sh). Copy this file to `.env` and fill in the token.
# `.env` is gitignored; never commit a real token.
#
# In the Cloudflare account you want to deploy to, create a token at
# https://dash.cloudflare.com/profile/api-tokens with the "Cloudflare
# Pages: Edit" permission. See docs/DEPLOY.md.
CLOUDFLARE_API_TOKEN=

# Set this when your API token can see more than one account (wrangler needs
# it to pick which). Find the account id in the dashboard URL or via
# `wrangler whoami`. Safe to set even with a single-account token.
CLOUDFLARE_ACCOUNT_ID=

# Optional. Overrides the Pages project name (default: envoy-lb-sim).
# CF_PROJECT=envoy-lb-sim
